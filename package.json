{
  "name": "@ttbooking/vue-select",
  "version": "1.0.0",
  "description": "Vue 3 select/multiselect component — lightweight drop-in replacement for jQuery select2",
  "type": "module",
  "main": "./dist/vue-select.umd.cjs",
  "module": "./dist/vue-select.js",
  "exports": {
    ".": {
      "import": "./dist/vue-select.js",
      "require": "./dist/vue-select.umd.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "types": "./index.d.ts",
  "files": [
    "dist",
    "index.d.ts"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run test && npm run build"
  },
  "keywords": [
    "vue",
    "vue3",
    "select",
    "multiselect",
    "select2",
    "dropdown",
    "combobox"
  ],
  "author": "Egor Gruzdev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ttbooking/vue-select.git"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "dependencies": {
    "lodash-es": "^4.17.21"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.0",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^26.0.0",
    "vite": "^5.0.0",
    "vitest": "^3.1.0"
  }
}
